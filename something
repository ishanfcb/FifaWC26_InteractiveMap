    overflow-y: hidden;
    -ms-overflow-style: none;
    scrollbar-width: none;
    transition: background-color 0.3s var(--ease-cubic), border-color 0.3s var(--ease-cubic);
}

.bottom-dock::-webkit-scrollbar {
    display: none;
}

.dock-content {
