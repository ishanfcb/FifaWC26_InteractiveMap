.slider-bg {
    position: absolute;
    top: 2px;
    left: 0;
    height: calc(100% - 4px);
    background-color: var(--pill-slider-bg);
    border-radius: 16px;
    z-index: 1;
    transition: background-color 0.3s var(--ease-cubic);
}

.pill-tab {
    padding: 0 16px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    cursor: pointer;
    transition: color var(--transition-speed);
    position: relative;
    z-index: 2;
    font-weight: 500;
}

.pill-tab.selected {
    color: var(--pill-selected-text);
    font-weight: 600;
}

/* BOTTOM DOCK (STANDINGS) */
.bottom-dock {
    position: fixed;
    bottom: 24px;
    left: 24px;
    right: 24px;
    height: 240px;
    background: var(--frosted-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: var(--frosted-border);
    border-radius: 24px;
    z-index: 900;
