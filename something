.top-right-controls {
    position: fixed;
    top: 24px;
    right: 24px;
    z-index: 1000;
}

.pill-tab-control {
    display: flex;
    background-color: var(--header-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: var(--frosted-border);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
